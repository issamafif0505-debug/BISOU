{
  "name": "bisou",
  "version": "1.0.0",
  "private": true,
  "description": "BISOU — Bijoux plaques or au Maroc. Boutique e-commerce COD sur Next.js 14 + Payload CMS 3.0.",
  "author": "BISOU Maroc",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.9.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "seed": "cross-env NODE_OPTIONS=\"--require ./scripts/seed-patch.cjs\" tsx src/seed/seed.ts",
    "generate-types": "payload generate:types",
    "payload": "tsx node_modules/payload/dist/bin/index.js",
    "payload:migrate": "tsx node_modules/payload/dist/bin/index.js migrate",
    "payload:migrate:create": "tsx node_modules/payload/dist/bin/index.js migrate:create",
    "check-wa": "node scripts/check-whatsapp-hardcoded.mjs || true",
    "clean": "rimraf .next node_modules/.cache"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "^3.0.0",
    "@payloadcms/next": "^3.0.0",
    "@payloadcms/richtext-lexical": "^3.0.0",
    "@payloadcms/ui": "^3.0.0",
    "cross-env": "^7.0.3",
    "graphql": "^16.9.0",
    "next": "15.4.11",
    "next-intl": "^3.21.0",
    "payload": "^3.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sass": "^1.99.0",
    "sharp": "^0.33.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.1.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.15",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "rimraf": "^6.0.1",
    "tailwindcss": "^3.4.13",
    "tailwindcss-rtl": "^0.9.0",
    "tsx": "^4.19.1",
    "typescript": "5.5.4"
  }
}
