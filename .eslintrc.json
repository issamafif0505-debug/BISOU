{
  "extends": ["next/core-web-vitals"],
  "ignorePatterns": [
    "legacy/**",
    "docs/**",
    ".next/**",
    "node_modules/**",
    "src/types/payload-types.ts"
  ],
  "rules": {
    "react/no-unescaped-entities": "off",
    "@next/next/no-img-element": "warn",
    "prefer-const": "error",
    "no-console": ["warn", { "allow": ["warn", "error", "info"] }]
  }
}
