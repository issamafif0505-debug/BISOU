# ============================================================
# BISOU — Variables d'environnement
# Copier vers .env.local et remplir les valeurs
# ============================================================

# --- Application ---
NEXT_PUBLIC_APP_URL=https://bisou.ma
NEXT_PUBLIC_SITE_NAME=BISOU
NODE_ENV=development

# --- Payload CMS ---
PAYLOAD_SECRET=change-me-to-a-long-random-string
PAYLOAD_PUBLIC_SERVER_URL=https://bisou.ma

# --- Database (Railway PostgreSQL) ---
DATABASE_URI=postgres://user:password@host:port/dbname

# --- WhatsApp Business Cloud API ---
WA_PHONE_NUMBER=212600000000                    # Numéro BISOU (sans +) — serveur
NEXT_PUBLIC_WA_PHONE_NUMBER=212600000000        # Même numéro, exposé au client (SSG/SSR)
WA_PHONE_NUMBER_ID=                              # ID numéro Meta
WA_BUSINESS_ACCOUNT_ID=                          # WABA ID
WA_ACCESS_TOKEN=                                 # Token permanent Cloud API
WA_WEBHOOK_VERIFY_TOKEN=                         # Secret webhook verification
WA_APP_SECRET=                                   # App secret pour signature webhooks

# --- UpConfirm ---
UPCONFIRM_API_KEY=
UPCONFIRM_WEBHOOK_SECRET=
UPCONFIRM_WORKSPACE_ID=

# --- Meta Pixel + Conversions API ---
NEXT_PUBLIC_META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=
META_CAPI_TEST_EVENT_CODE=                       # Pour tester en dev

# --- Alya Pay BNPL ---
ALYA_PAY_MERCHANT_ID=
ALYA_PAY_API_KEY=
ALYA_PAY_WEBHOOK_SECRET=
ALYA_PAY_ENVIRONMENT=sandbox                     # sandbox | production

# --- Cloudinary ---
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=bisou_products

# --- Email (optionnel, pour admin notifications) ---
RESEND_API_KEY=
EMAIL_FROM=commandes@bisou.ma

# --- Admin initial (seed) ---
ADMIN_EMAIL=admin@bisou.ma
ADMIN_PASSWORD=change-me-on-first-login

# --- Analytics (optionnel) ---
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=bisou.ma
